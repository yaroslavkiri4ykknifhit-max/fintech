# Google Sheets Configurations
# Required if you want to sync your balance and transaction history in real-time
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_web_app_id/exec

# Optional direct Sheets API (read-only) variables
VITE_GOOGLE_SHEETS_SPREADSHEET_ID=
VITE_GOOGLE_SHEETS_API_KEY=

# Groq API Configuration (for live receipt scanning)
# Get your API key from console.groq.com
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Lock Screen Configuration
# 4-digit PIN code to lock your budget tracker (e.g. 1234)
# If left blank, you can create a custom PIN on first launch directly in your browser.
VITE_APP_PASSCODE=
